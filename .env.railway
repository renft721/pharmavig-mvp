# Railway.app Production Configuration
# Copy these variables to Railway UI and set their values

# Database (Railway provides this automatically when you add PostgreSQL)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis (Railway provides this automatically when you add Redis)
# REDIS_URL=redis://default:password@host:6379

# FastAPI
DEBUG=False
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Security - IMPORTANT: Generate a strong random value
# SECRET_KEY=<generate-with: python -c "import secrets; print(secrets.token_urlsafe(32))">

# Scrapers
AERZTEBLATT_BASE_URL=https://www.aerzteblatt.de
SCRAPER_TIMEOUT=30
SCRAPER_RATE_LIMIT=2.0

# NLP
SPACY_MODEL=en_core_web_sm
USE_GPT4_FALLBACK=False
# OPENAI_API_KEY=sk-... (if needed)

# Auth
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
