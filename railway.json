{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "context": ".",
    "dockerfilePath": "backend/Dockerfile"
  },
  "deploy": {
    "startCommand": "bash ./entrypoint.sh",
    "healthchecks": {
      "readiness": {
        "path": "/health"
      }
    }
  },
  "variables": {
    "PYTHON_VERSION": "3.11",
    "PORT": "8000",
    "DEBUG": "False"
  }
}
